# Database
DATABASE_URL="postgresql://user:password@host:5432/busybees?schema=public"

# NextAuth.js
NEXTAUTH_URL="https://your-railway-app.up.railway.app"
NEXTAUTH_SECRET="your-secret-key-min-32-chars-long"

# OAuth (Optional - Google)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email (Resend)
RESEND_API_KEY="re_your-resend-api-key"

# App Configuration
NODE_ENV="production"
